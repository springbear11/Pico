{
  "version": 6,
  "configurePresets": [
    {
      "name": "vs2022-qt6",
      "displayName": "VS2022 Qt 6.9.1 x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
