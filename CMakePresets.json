      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "D:/QT/6.9.1/msvc2022_64",
        "PICOATE_BUILD_UI": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-qt6-debug",
      "configurePreset": "vs2022-qt6",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-qt6-all-debug",
      "configurePreset": "vs2022-qt6-all",
